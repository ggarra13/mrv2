[Desktop Entry]
Name=usdviewer v@mrv2_VERSION@
Comment=Professional Video and Flipbook player
Exec=/usr/local/@mrv2_NAME@-v@mrv2_VERSION@-Linux-64/bin/usdviewer.sh %F
Icon=/usr/share/icons/hicolor/256x256/apps/usdviewer-v@mrv2_VERSION@.png
Categories=AudioVideo;Player;Video;Graphics;2DGraphics;RasterGraphics;FLTK;
Comment[en_US]=OpenUSD Previewer
StartupNotify=false
Terminal=false
Type=Application
Categories=Graphics;
